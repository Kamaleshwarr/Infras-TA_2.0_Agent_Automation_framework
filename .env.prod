# PROD Environment — read-only smoke checks only
ENV=PROD
BROWSER=chromium
HEADLESS=true
BASE_URL=https://secure.transamerica.com
WORKERS=1
RETRIES=0
ENABLE_TRACING=false
RECORD_VIDEO=false
SCREENSHOT_ON_FAILURE=true
LOG_LEVEL=WARN
TAGS=@smoke

# Required for @requires-credentials scenarios
# AGENT_USERNAME=
# AGENT_PASSWORD=
