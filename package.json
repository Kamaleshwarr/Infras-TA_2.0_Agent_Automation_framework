{
  "name": "playwright-automation-framework",
  "version": "1.2.0",
  "description": "Enterprise-grade Playwright BDD automation framework with TypeScript, Cucumber, and Allure",
  "main": "index.js",
  "scripts": {
    "test": "cucumber-js",
    "test:headed": "cross-env HEADLESS=false cucumber-js",
    "test:parallel": "cross-env WORKERS=4 cucumber-js",
    "test:parallel:headed": "cross-env HEADLESS=false WORKERS=4 cucumber-js",
    "test:smoke": "cross-env TAGS=@smoke cucumber-js",
    "test:regression": "cross-env TAGS=@regression cucumber-js",
    "test:sanity": "cross-env TAGS=@sanity cucumber-js",
    "test:critical": "cross-env TAGS=@critical cucumber-js",
    "test:ui": "cross-env TAGS=@ui cucumber-js",
    "test:wip": "cross-env TAGS=@wip cucumber-js",
    "test:tags": "cucumber-js --tags",
    "test:cross-browser": "node scripts/run-cross-browser.js",
    "test:retry": "node scripts/run-with-retry.js",
    "test:env:dev": "cross-env ENV=DEV cucumber-js",
    "test:env:qa": "cross-env ENV=QA cucumber-js",
    "test:env:uat": "cross-env ENV=UAT cucumber-js",
    "test:env:prod": "cross-env ENV=PROD cucumber-js",
    "allure:generate": "allure generate src/reports/allure-results --clean -o src/reports/allure-report",
    "allure:open": "allure open src/reports/allure-report",
    "report": "npm run allure:generate",
    "report:open": "npm run allure:open",
    "lint": "npm run lint:eslint && npm run lint:types && npm run format:check",
    "lint:eslint": "eslint .",
    "lint:types": "tsc --noEmit",
    "lint:fix": "eslint . --fix && prettier --write .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "doctor": "ts-node scripts/doctor.ts",
    "prepare": "husky",
    "postinstall": "playwright install chromium firefox webkit"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{js,json,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "keywords": [
    "playwright",
    "cucumber",
    "typescript",
    "bdd",
    "allure",
    "automation"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "winston": "^3.17.0"
  },
  "devDependencies": {
    "@cucumber/cucumber": "^11.2.0",
    "@eslint/js": "^9.17.0",
    "@playwright/test": "^1.61.1",
    "@types/node": "^22.10.2",
    "allure-commandline": "^2.32.0",
    "allure-cucumberjs": "^3.0.7",
    "cross-env": "^7.0.3",
    "dotenv": "^16.4.7",
    "eslint": "^9.17.0",
    "eslint-config-prettier": "^9.1.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.3.0",
    "playwright": "^1.49.1",
    "prettier": "^3.4.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.2"
  }
}
