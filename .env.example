# Environment: DEV | QA | UAT | PROD
ENV=QA

# Browser: chromium | firefox | webkit
BROWSER=chromium

# Run headless (true | false)
HEADLESS=true

# Optional tag filter for Cucumber (e.g. @smoke)
TAGS=

# Override base URL (optional — defaults per environment)
# BASE_URL=https://www.saucedemo.com

# Timeouts (milliseconds)
TIMEOUT=60000
ACTION_TIMEOUT=15000
NAVIGATION_TIMEOUT=30000

# Parallel workers
WORKERS=1

# Retries on failure
RETRIES=0

# Slow motion delay (ms) — useful for debugging
SLOW_MO=0
