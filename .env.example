# Environment: DEV | QA | UAT | PROD
ENV=QA

# Browser: chromium | firefox | webkit
BROWSER=chromium

# Run headless (true | false) — default is headless
HEADLESS=true

# Optional tag filter for Cucumber (e.g. @smoke)
TAGS=

# Override base URL (optional — defaults per environment)
# BASE_URL=https://www.saucedemo.com

# Timeouts (milliseconds)
TIMEOUT=60000
ACTION_TIMEOUT=15000
NAVIGATION_TIMEOUT=30000

# Parallel workers (1 = sequential, 4+ recommended for CI)
WORKERS=1

# Retries on failure
RETRIES=0

# Slow motion delay (ms) — useful for debugging
SLOW_MO=0

# Performance toggles (disable in CI for faster runs if artifacts not needed)
ENABLE_TRACING=true
RECORD_VIDEO=true

# Log level: DEBUG | INFO | WARN | ERROR
LOG_LEVEL=INFO
