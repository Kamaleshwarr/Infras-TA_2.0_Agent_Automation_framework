# Local overrides — copy from .env.example or an environment file
# cp .env.qa .env

ENV=QA
BROWSER=chromium
HEADLESS=true

# Optional tag filter (e.g. @smoke)
TAGS=

# Override base URL when targeting a live environment
# BASE_URL=https://secure.transamerica.com

# Timeouts (milliseconds)
TIMEOUT=60000
ACTION_TIMEOUT=15000
NAVIGATION_TIMEOUT=30000

# Parallel workers (1 = sequential, 4+ recommended for CI)
WORKERS=1

# Retries for transient failures (browser launch, network)
RETRIES=1

# Slow motion delay (ms) — useful for debugging
SLOW_MO=0

# Artifact strategy (retain-on-failure)
ENABLE_TRACING=false
RECORD_VIDEO=false
SCREENSHOT_ON_FAILURE=true

# Log level: DEBUG | INFO | WARN | ERROR
LOG_LEVEL=INFO
